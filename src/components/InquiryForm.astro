---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  preselect?: string;
}
const { preselect = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? 'YOUR-WEB3FORMS-ACCESS-KEY';

const options = [
  { value: 'consult', label: t('form.option.consult') },
  { value: 'audit', label: t('form.option.audit') },
  { value: 'foundations', label: t('form.option.foundations') },
  { value: 'retainer', label: t('form.option.retainer') },
  { value: 'combo', label: t('form.option.combo') },
  { value: 'unsure', label: t('form.option.unsure') },
];
---

<form class="inquiry-form space-y-4" data-inquiry-form>
  <input type="hidden" name="access_key" value={accessKey} />
  <input type="hidden" name="subject" value="Novi upit — seolick.me" />
  <input type="hidden" name="from_name" value="SEO LICK Website" />
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

  <div class="grid sm:grid-cols-2 gap-4">
    <input type="text" name="name" required placeholder={t('form.name')}
      class="w-full px-4 py-3 bg-white/[0.03] border border-white/15 rounded-md text-[15px] text-white placeholder:text-white/40 focus:border-red outline-none" />
    <input type="email" name="email" required placeholder={t('form.email')}
      class="w-full px-4 py-3 bg-white/[0.03] border border-white/15 rounded-md text-[15px] text-white placeholder:text-white/40 focus:border-red outline-none" />
  </div>
  <div class="grid sm:grid-cols-2 gap-4">
    <input type="text" name="company" placeholder={t('form.company')}
      class="w-full px-4 py-3 bg-white/[0.03] border border-white/15 rounded-md text-[15px] text-white placeholder:text-white/40 focus:border-red outline-none" />
    <input type="tel" name="phone" placeholder={t('form.phone')}
      class="w-full px-4 py-3 bg-white/[0.03] border border-white/15 rounded-md text-[15px] text-white placeholder:text-white/40 focus:border-red outline-none" />
  </div>
  <select name="service" required
    class="w-full px-4 py-3 bg-white/[0.03] border border-white/15 rounded-md text-[15px] text-white focus:border-red outline-none">
    <option value="" disabled selected={!preselect} class="bg-black text-white">{t('form.service')}</option>
    {options.map((o) => (
      <option value={o.value} selected={preselect === o.value} class="bg-black text-white">{o.label}</option>
    ))}
  </select>
  <textarea name="message" rows="3" placeholder={t('form.message')}
    class="w-full px-4 py-3 bg-white/[0.03] border border-white/15 rounded-md text-[15px] text-white placeholder:text-white/40 focus:border-red outline-none"></textarea>

  <button type="submit" class="btn btn-primary w-full">{t('form.submit')}</button>

  <p data-form-status class="text-sm hidden" data-success={t('form.success')} data-error={t('form.error')}></p>
</form>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-inquiry-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.querySelector<HTMLParagraphElement>('[data-form-status]')!;
      const btn = form.querySelector<HTMLButtonElement>('button[type=submit]')!;
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = '…';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json();
        status.classList.remove('hidden', 'text-red');
        if (data.success) {
          status.textContent = status.dataset.success!;
          status.classList.add('text-green-600');
          form.reset();
        } else {
          status.textContent = status.dataset.error!;
          status.classList.add('text-red');
        }
      } catch {
        status.classList.remove('hidden');
        status.textContent = status.dataset.error!;
        status.classList.add('text-red');
      } finally {
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  });
</script>
