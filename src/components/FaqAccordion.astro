---
interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  items: FaqItem[];
}
const { items } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((i) => ({
    '@type': 'Question',
    name: i.q,
    acceptedAnswer: { '@type': 'Answer', text: i.a },
  })),
};
---

<div class="divide-y divide-gray-200 border-y border-gray-200">
  {items.map((item) => (
    <details class="group">
      <summary class="flex items-center justify-between gap-4 py-5 cursor-pointer list-none font-bold text-lg">
        {item.q}
        <span class="text-red text-2xl leading-none transition-transform group-open:rotate-45">+</span>
      </summary>
      <p class="pb-5 text-gray-700 leading-relaxed">{item.a}</p>
    </details>
  ))}
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
