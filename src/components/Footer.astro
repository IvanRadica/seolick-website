---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizePath(path, lang);
const year = new Date().getFullYear();

const navLinks = [
  { href: p('/usluge'), label: t('nav.services') },
  { href: p('/lick'), label: t('nav.lick') },
  { href: p('/#faq'), label: t('nav.faq') },
  { href: p('/karijere'), label: t('nav.careers') },
  { href: p('/kontakt'), label: t('nav.contact') },
];
---

<footer class="relative overflow-hidden border-t border-black/[0.12] mt-0 bg-white">
  <div class="container-page pt-20 pb-10 grid gap-12 md:grid-cols-3">
    <div>
      <img src="/brand/logo-horizontal.svg" alt="SEO LICK" class="h-[32px] w-auto block mb-4" width="720" height="119" loading="lazy" />
      <p class="text-black/55 text-sm max-w-xs leading-relaxed">{t('footer.tagline')}</p>
      <p class="eyebrow mt-5">Links · Infrastructure · Content · Keywords</p>
    </div>

    <div>
      <h3 class="font-mono text-[11px] uppercase tracking-[0.2em] text-black/45 mb-5">{t('footer.links.title')}</h3>
      <ul class="space-y-3 text-[15px]">
        {navLinks.map((l) => (
          <li><a href={l.href} class="text-black/70 hover:text-ink transition-colors">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-mono text-[11px] uppercase tracking-[0.2em] text-black/45 mb-5">{t('footer.contact.title')}</h3>
      <ul class="space-y-3 text-[15px]">
        <li><a href="mailto:info@seolick.me" class="text-black/70 hover:text-ink transition-colors">info@seolick.me</a></li>
        <li><a href="https://seolick.me" class="text-black/70 hover:text-ink transition-colors">seolick.me</a></li>
      </ul>
      <p class="text-black/45 text-xs font-mono mt-6">Split, Hrvatska</p>
    </div>
  </div>

  <div class="border-t border-black/[0.12]">
    <div class="container-page py-6 text-[11px] font-mono text-black/45 flex flex-col sm:flex-row justify-between gap-2">
      <span>&copy; {year} SEO LICK. {t('footer.rights')}</span>
      <span>We LICK websites. For organic growth.</span>
    </div>
  </div>

  <!-- Oversized wordmark bleeding off the bottom edge -->
  <div class="select-none pointer-events-none px-4" aria-hidden="true">
    <div
      class="font-display font-black tracking-tight whitespace-nowrap text-center leading-[0.78] text-black/[0.05]"
      style="font-size: clamp(3.25rem, 19vw, 15rem); margin-bottom: -0.12em;"
    >
      SEO LICK
    </div>
  </div>
</footer>
