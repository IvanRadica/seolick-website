---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizePath(path, lang);
const year = new Date().getFullYear();

const navLinks = [
  { href: p('/usluge'), label: t('nav.services') },
  { href: p('/lick'), label: t('nav.lick') },
  { href: p('/#faq'), label: t('nav.faq') },
  { href: p('/kontakt'), label: t('nav.contact') },
];
---

<footer class="relative overflow-hidden border-t border-white/10 mt-0">
  <div class="container-page pt-20 pb-10 grid gap-12 md:grid-cols-3">
    <div>
      <div class="font-display font-black text-xl tracking-[0.16em] uppercase mb-4">
        SEO<span class="text-red">LICK</span>
      </div>
      <p class="text-white/45 text-sm max-w-xs leading-relaxed">{t('footer.tagline')}</p>
      <p class="eyebrow mt-5">Links · Infrastructure · Content · Keywords</p>
    </div>

    <div>
      <h3 class="font-mono text-[11px] uppercase tracking-[0.2em] text-white/30 mb-5">{t('footer.links.title')}</h3>
      <ul class="space-y-3 text-[15px]">
        {navLinks.map((l) => (
          <li><a href={l.href} class="text-white/70 hover:text-white transition-colors">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-mono text-[11px] uppercase tracking-[0.2em] text-white/30 mb-5">{t('footer.contact.title')}</h3>
      <ul class="space-y-3 text-[15px]">
        <li><a href="mailto:ivan@seolick.me" class="text-white/70 hover:text-white transition-colors">ivan@seolick.me</a></li>
        <li><a href="https://seolick.me" class="text-white/70 hover:text-white transition-colors">seolick.me</a></li>
      </ul>
      <p class="text-white/30 text-xs font-mono mt-6">Split, Hrvatska</p>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-page py-6 text-[11px] font-mono text-white/30 flex flex-col sm:flex-row justify-between gap-2">
      <span>&copy; {year} SEO LICK. {t('footer.rights')}</span>
      <span>We LICK websites. For organic growth.</span>
    </div>
  </div>

  <!-- Oversized wordmark bleeding off the bottom edge -->
  <div class="select-none pointer-events-none px-4" aria-hidden="true">
    <div
      class="font-display font-black tracking-tight whitespace-nowrap text-center leading-[0.78] text-white/[0.04]"
      style="font-size: clamp(3.25rem, 19vw, 15rem); margin-bottom: -0.12em;"
    >
      SEO LICK
    </div>
  </div>
</footer>
