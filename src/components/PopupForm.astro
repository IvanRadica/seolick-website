---
import { getLangFromUrl, localizePath } from '../i18n/utils';
import InquiryForm from './InquiryForm.astro';

const lang = getLangFromUrl(Astro.url);
const p = (path: string) => localizePath(path, lang);

const copy =
  lang === 'hr'
    ? {
        title: 'Tržište nagrađuje konkurenciju, a vaša ponuda je bolja?',
        subtitle: 'L.I.C.K. je prvi korak da se to promijeni.',
        lead: 'Ostavite nam svoje podatke i javljamo se u što kraćem roku.',
        services: 'Više o uslugama',
        lick: 'Što znači L.I.C.K.?',
      }
    : {
        title: 'The market rewards your competitors, but your offer is better?',
        subtitle: 'L.I.C.K. is the first step to change that.',
        lead: 'Leave us your details and we’ll get back to you shortly.',
        services: 'More about services',
        lick: 'What does L.I.C.K. mean?',
      };
---

<div data-popup class="fixed inset-0 z-50 hidden items-center justify-center p-4">
  <div data-popup-overlay class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="relative bg-white border border-black/10 rounded-[2px] max-w-xl w-full max-h-[90vh] overflow-y-auto shadow-2xl">
    <button data-close-popup aria-label="Close"
      class="absolute top-4 right-4 text-black/40 hover:text-ink text-2xl leading-none">&times;</button>
    <div class="p-8">
      <p class="eyebrow mb-2">FIRST LICK</p>
      <h2 class="text-2xl font-black leading-tight mb-1 text-ink">{copy.title}</h2>
      <p class="text-lg font-bold text-red mb-3">{copy.subtitle}</p>
      <p class="text-black/55 text-sm mb-6">{copy.lead}</p>

      <InquiryForm />

      <div class="flex flex-wrap gap-x-5 gap-y-2 mt-5 text-xs font-mono">
        <a href={p('/usluge')} class="text-black/50 hover:text-ink underline">{copy.services}</a>
        <a href={p('/lick')} class="text-black/50 hover:text-ink underline">{copy.lick}</a>
      </div>
    </div>
  </div>
</div>

<script>
  const popup = document.querySelector('[data-popup]');
  const open = () => {
    popup?.classList.remove('hidden');
    popup?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    popup?.classList.add('hidden');
    popup?.classList.remove('flex');
    document.body.style.overflow = '';
  };
  document.querySelectorAll('[data-open-popup]').forEach((b) => b.addEventListener('click', open));
  document.querySelectorAll('[data-close-popup], [data-popup-overlay]').forEach((b) =>
    b.addEventListener('click', close)
  );
  document.addEventListener('keydown', (e) => e.key === 'Escape' && close());
</script>
