---
import { getLangFromUrl, useTranslations, localizePath, getAlternatePath, isV2Track } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizePath(path, lang);
const other = lang === 'hr' ? 'en' : 'hr';
const altPath = getAlternatePath(Astro.url, other);

// Keep navigation inside the v2 test track when viewing a v2 page.
const isV2 = isV2Track(Astro.url);
const home = isV2 ? '/v2' : '/';

const navLinks = [
  { href: p(isV2 ? '/usluge-v2' : '/usluge'), label: t('nav.services') },
  { href: p(isV2 ? '/lick-v2' : '/lick'), label: t('nav.lick') },
  { href: p(isV2 ? '/v2#faq' : '/#faq'), label: t('nav.faq') },
  { href: p('/kontakt'), label: t('nav.contact') },
];
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-gray-200">
  <nav class="container-page flex items-center justify-between h-16">
    <a href={p(home)} class="flex items-center shrink-0" aria-label="SEO LICK">
      <img
        src="/SEOLICK_logo_horizontal.png"
        alt="SEO LICK"
        width="826"
        height="182"
        class="h-7 md:h-8 w-auto"
      />
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm font-medium">
      {navLinks.map((l) => (
        <li><a href={l.href} class="hover:text-red transition-colors">{l.label}</a></li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a href={altPath} class="font-mono text-xs font-bold text-gray-500 hover:text-black transition-colors">
        {other.toUpperCase()}
      </a>
      <button data-open-popup class="btn btn-primary text-sm hidden sm:inline-flex">
        {t('nav.cta')}
      </button>
      <button data-toggle-menu class="md:hidden p-2" aria-label="Menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <div data-mobile-menu class="hidden md:hidden border-t border-gray-200 bg-white">
    <ul class="container-page py-4 flex flex-col gap-4 text-sm font-medium">
      {navLinks.map((l) => (
        <li><a href={l.href} class="block hover:text-red transition-colors">{l.label}</a></li>
      ))}
      <li><button data-open-popup class="btn btn-primary w-full">{t('nav.cta')}</button></li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-toggle-menu]');
  const menu = document.querySelector('[data-mobile-menu]');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
