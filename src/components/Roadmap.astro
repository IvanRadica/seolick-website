---
import { getLangFromUrl } from '../i18n/utils';
import { roadmap } from '../content/roadmap';

const lang = getLangFromUrl(Astro.url);
const pick = (o: { hr: string; en: string }) => (lang === 'hr' ? o.hr : o.en);
const h = roadmap.heading[lang];
const months = [1, 2, 3, 4, 5, 6];

type Cell =
  | { kind: 'label'; text: string; bg: string; fg: string; rowStart: number; rowEnd: number }
  | { kind: 'task'; text: string; bg: string; fg: string; row: number; colStart: number; colEnd: number };

const cells: Cell[] = [];
let row = 2;
for (const p of roadmap.pillars) {
  const startRow = row;
  cells.push({ kind: 'label', text: pick(p), bg: p.bg, fg: p.fg, rowStart: startRow, rowEnd: startRow + p.lanes.length });
  p.lanes.forEach((lane, li) => {
    for (const task of lane) {
      cells.push({
        kind: 'task',
        text: pick(task),
        bg: p.bg,
        fg: p.fg,
        row: startRow + li,
        colStart: task.start + 1,
        colEnd: task.end + 2,
      });
    }
  });
  row += p.lanes.length;
}
---

<div>
  <p class="eyebrow mb-3">{h.eyebrow}</p>
  <h2 class="text-3xl md:text-4xl font-black max-w-3xl">{h.title}</h2>
  <p class="mt-4 text-gray-600 max-w-2xl">{h.subtitle}</p>

  <div class="mt-10 overflow-x-auto pb-2">
    <div
      class="rm-grid grid gap-1.5"
      style="min-width:780px; grid-template-columns: 2.75rem repeat(6, minmax(0,1fr)); grid-auto-rows: minmax(2.5rem, auto);"
    >
      <div class="rm-playhead absolute" aria-hidden="true"></div>
      {months.map((m) => (
        <div class="self-end pb-2 text-sm font-bold text-gray-500" style={`grid-column:${m + 1}/${m + 2}; grid-row:1;`}>
          {pick(roadmap.months)} {m}
        </div>
      ))}

      {cells.map((cell) =>
        cell.kind === 'label' ? (
          <div
            class="grid place-items-center rounded font-mono font-black tracking-widest uppercase"
            style={`grid-column:1; grid-row:${cell.rowStart}/${cell.rowEnd}; background:${cell.bg}; color:${cell.fg}; writing-mode:vertical-rl; transform:rotate(180deg); font-size:10px;`}
          >
            {cell.text}
          </div>
        ) : (
          <div
            class="rm-task grid place-items-center rounded px-2 py-1 text-center font-medium"
            style={`grid-column:${cell.colStart}/${cell.colEnd}; grid-row:${cell.row}; background:${cell.bg}; color:${cell.fg}; font-size:11px; line-height:1.25; --d:${(cell.colStart - 1) * 130}ms;`}
          >
            {cell.text}
          </div>
        )
      )}
    </div>
  </div>
</div>
