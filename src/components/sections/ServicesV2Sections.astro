---
import { getLangFromUrl } from '../../i18n/utils';
import { servicesV2Content } from '../../content/services-v2';
import InquiryForm from '../InquiryForm.astro';

const lang = getLangFromUrl(Astro.url);
const c = servicesV2Content[lang];
---

<section class="bg-black text-white">
  <div class="container-page py-20 md:py-24 text-center">
    <p class="eyebrow mb-3">{c.eyebrow}</p>
    <h1 class="text-4xl md:text-5xl font-black">{c.title}</h1>
    <p class="mt-2 text-lg text-red font-bold italic">{c.subtitle}</p>
    <p class="mt-6 text-gray-200 max-w-2xl mx-auto leading-relaxed">{c.intro}</p>
  </div>
</section>

<div class="container-page py-16 md:py-24">
  <div class="grid md:grid-cols-3 gap-6">
    {c.trio.map((s, i) => (
      <article class="relative flex flex-col border border-gray-200 rounded-xl p-6 md:p-8 bg-white" data-reveal style={`--d:${i * 140}ms`}>
        <div class="font-mono text-red font-black text-sm mb-2">{s.num}</div>
        <h2 class="text-2xl font-black">{s.name}</h2>
        <div class="mt-3 font-mono text-sm font-bold">{s.price}</div>
        <p class="text-gray-500 mt-3 text-sm italic">{s.tagline}</p>
        <p class="text-gray-700 mt-4 leading-relaxed text-sm">{s.desc}</p>
        <ul class="mt-5 space-y-2 text-sm text-gray-700 flex-1">
          {s.bullets.map((b) => (
            <li class="flex gap-2"><span class="text-red font-bold">→</span><span>{b}</span></li>
          ))}
        </ul>
        <div class="mt-6">
          <button data-open-popup class="btn btn-primary text-sm w-full">{c.cta}</button>
        </div>
        {i < c.trio.length - 1 && (
          <div class="svc-arrow hidden md:flex absolute top-1/2 -right-3 z-10 -translate-y-1/2 items-center justify-center w-6 h-6 rounded-full bg-red text-white font-black text-xs">→</div>
        )}
      </article>
    ))}
  </div>
  <p class="mt-8 text-center text-gray-500 text-sm max-w-3xl mx-auto leading-relaxed">{c.pathNote}</p>
</div>

<section class="bg-gray-50 border-y border-gray-200">
  <div class="container-page py-16 md:py-24">
    <div class="text-center">
      <p class="mx-auto mb-6 max-w-xl text-sm font-mono text-gray-500">{c.tiers.bridge}</p>
      <p class="eyebrow mb-3">{c.tiers.eyebrow}</p>
      <h2 class="text-3xl md:text-4xl font-black">{c.tiers.title}</h2>
      <p class="mt-3 text-gray-700">{c.tiers.subtitle}</p>
    </div>
    <div class="mt-12 grid md:grid-cols-3 gap-6 items-stretch">
      {c.tiers.plans.map((p, i) => (
        <div class={`relative flex flex-col rounded-xl p-6 md:p-8 ${p.featured ? 'bg-black text-white border-2 border-red' : 'bg-white border border-gray-200'}`} data-reveal style={`--d:${i * 120}ms`}>
          {p.featured && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-red text-white font-mono text-xs font-bold px-3 py-1 rounded">{c.tiers.featuredLabel}</div>
          )}
          <h3 class="font-black text-xl">{p.name}</h3>
          <div class={`mt-1 font-mono text-xs ${p.featured ? 'text-gray-300' : 'text-gray-500'}`}>{p.capacity}</div>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-3xl font-black" data-countup={p.price}>{p.price}</span>
            <span class={`text-sm ${p.featured ? 'text-gray-300' : 'text-gray-500'}`}>{c.tiers.perMonth}</span>
          </div>
          <p class={`mt-5 text-sm leading-relaxed flex-1 ${p.featured ? 'text-gray-200' : 'text-gray-700'}`}>{p.team}</p>
          <div class="mt-6">
            <button data-open-popup class="btn btn-primary text-sm w-full">{c.tiers.cta}</button>
          </div>
        </div>
      ))}
    </div>
    <p class="mt-8 text-center text-gray-500 text-sm">{c.tiers.note}</p>
  </div>
</section>

<div class="container-page py-16 md:py-24">
  <div class="text-center">
    <p class="eyebrow mb-3">{c.width.eyebrow}</p>
    <h2 class="text-3xl md:text-4xl font-black">{c.width.title}</h2>
    <p class="mt-3 text-gray-700">{c.width.subtitle}</p>
  </div>
  <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {c.width.items.map((it, i) => (
      <div class="flex flex-col border border-gray-200 rounded-xl p-6 bg-white" data-reveal style={`--d:${i * 110}ms`}>
        <h3 class="font-bold text-lg">{it.name}</h3>
        <p class="text-gray-700 mt-2 text-sm leading-relaxed flex-1">{it.desc}</p>
        <div class="mt-4 inline-block self-start font-mono text-xs border border-gray-200 rounded px-3 py-1">{it.price}</div>
      </div>
    ))}
  </div>
</div>

<section id="upit" class="bg-gray-50 border-t border-gray-200 scroll-mt-16">
  <div class="container-page py-20 md:py-24 grid md:grid-cols-2 gap-12 items-start">
    <div>
      <h2 class="text-3xl md:text-4xl font-black leading-tight">{c.formTitle}</h2>
      <p class="mt-4 text-lg text-gray-700">{c.formSub}</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-6 md:p-8">
      <InquiryForm />
    </div>
  </div>
</section>
