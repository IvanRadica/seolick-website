---
import { getLangFromUrl, localizePath } from '../../i18n/utils';
import { lickContent } from '../../content/lick';
import Roadmap from '../Roadmap.astro';

const lang = getLangFromUrl(Astro.url);
const p = (path: string) => localizePath(path, lang);
const c = lickContent[lang];
---

<section class="bg-black text-white">
  <div class="container-page py-20 md:py-28">
    <p class="eyebrow mb-4">{c.eyebrow}</p>
    <h1 class="text-4xl md:text-6xl font-black leading-[1.05] max-w-4xl">{c.title}</h1>
    <p class="mt-4 text-xl text-red font-bold">{c.subtitle}</p>
    <div class="mt-8 max-w-3xl space-y-4 text-gray-200 leading-relaxed">
      <p>{c.intro1}</p>
      <p>{c.intro2}</p>
      <p>{c.intro3}</p>
    </div>
    <div class="mt-10 flex gap-3">
      {c.pillars.map((pl) => (
        <a href={`#${pl.k}`} class="font-mono font-black text-2xl w-12 h-12 grid place-items-center border border-gray-700 rounded hover:border-red hover:text-red transition-colors">{pl.k}</a>
      ))}
    </div>
  </div>
</section>

{c.pillars.map((pl, i) => (
  <section id={pl.k} class={`scroll-mt-16 ${i % 2 === 1 ? 'bg-gray-50 border-y border-gray-200' : ''}`}>
    <div class="container-page py-16 md:py-24 grid md:grid-cols-3 gap-12">
      <div class="md:col-span-2">
        <h2 class="flex items-baseline font-black mb-6">
          <span class="font-mono text-5xl text-red">{pl.k}</span><span class="text-3xl">{pl.title.slice(1)}</span>
        </h2>
        <h3 class="font-bold text-lg text-gray-500 mb-4">{pl.role}</h3>
        <div class="space-y-4 text-gray-700 leading-relaxed max-w-2xl">
          {pl.body.map((para) => <p>{para}</p>)}
        </div>
      </div>
      <div class="md:pt-2">
        <p class="eyebrow mb-4">{c.benefitsTitle}</p>
        <ul class="space-y-3">
          {pl.benefits.map((b) => (
            <li class="flex gap-3 text-sm text-gray-700">
              <span class="text-red font-bold">→</span>{b}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
))}

<section class="bg-gray-50 border-y border-gray-200">
  <div class="container-page py-16 md:py-24">
    <Roadmap />
  </div>
</section>

<section class="container-page py-20 md:py-28 text-center">
  <h2 class="text-3xl md:text-5xl font-black max-w-3xl mx-auto leading-tight">{c.ctaTitle}</h2>
  <a href={p('/usluge')} class="btn btn-primary text-base px-9 py-4 mt-9">{c.cta} &rarr;</a>
</section>
