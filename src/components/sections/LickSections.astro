---
import { getLangFromUrl, localizePath } from '../../i18n/utils';
import { lickContent } from '../../content/lick';
import Roadmap from '../Roadmap.astro';

const lang = getLangFromUrl(Astro.url);
const p = (path: string) => localizePath(path, lang);
const c = lickContent[lang];
---

<!-- HEADER -->
<section class="section section-first pt-28 md:pt-32">
  <div class="container-page" data-reveal>
    <p class="eyebrow mb-4">{c.eyebrow}</p>
    <h1 class="font-display text-4xl md:text-6xl font-black leading-[1.05] max-w-4xl tracking-tight text-ink">{c.title}</h1>
    <p class="mt-4 text-xl text-red font-bold">{c.subtitle}</p>
    <div class="mt-8 max-w-3xl space-y-4 text-black/65 leading-relaxed">
      <p>{c.intro1}</p>
      <p>{c.intro2}</p>
      <p>{c.intro3}</p>
    </div>
    <div class="mt-10 flex gap-3">
      {c.pillars.map((pl) => (
        <a href={`#${pl.k}`} class="font-display font-black text-2xl w-12 h-12 grid place-items-center border border-black/[0.15] text-ink hover:border-red hover:text-red transition-colors">{pl.k}</a>
      ))}
    </div>
  </div>
</section>

{c.pillars.map((pl) => (
  <section id={pl.k} class="section scroll-mt-16">
    <div class="container-page grid md:grid-cols-3 gap-12">
      <div class="md:col-span-2" data-reveal>
        <h2 class="flex items-baseline font-black mb-6">
          <span class="font-display text-5xl text-red">{pl.k}</span>
          <span class="font-display text-3xl text-ink">{pl.title.slice(1)}</span>
        </h2>
        <h3 class="font-bold text-lg text-black/50 mb-4">{pl.role}</h3>
        <div class="space-y-4 text-black/65 leading-relaxed max-w-2xl">
          {pl.body.map((para) => <p>{para}</p>)}
        </div>
      </div>
      <div class="md:pt-2" data-reveal style="--d:120ms">
        <p class="eyebrow mb-4">{c.benefitsTitle}</p>
        <ul class="space-y-3">
          {pl.benefits.map((b) => (
            <li class="flex gap-3 text-sm text-black/70">
              <span class="text-red font-bold">→</span>{b}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
))}

<!-- ROADMAP — warm band -->
<section class="section section-band">
  <div class="container-page">
    <Roadmap />
  </div>
</section>

<!-- CTA -->
<section class="section">
  <div class="container-page text-center" data-reveal>
    <h2 class="section-title max-w-3xl mx-auto">{c.ctaTitle}</h2>
    <a href={p('/usluge')} class="btn btn-primary text-base px-9 py-4 mt-9">{c.cta} &rarr;</a>
  </div>
</section>
