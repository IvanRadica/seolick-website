---
import { getLangFromUrl } from '../../i18n/utils';
import InquiryForm from '../InquiryForm.astro';

const lang = getLangFromUrl(Astro.url);
const c =
  lang === 'hr'
    ? {
        eyebrow: 'Kontakt',
        title: 'Konkurencija ne čeka, nemojte ni vi.',
        lead: 'Ostavite nam svoje podatke i javljamo se u što kraćem roku. Rado ćemo se upoznati s vašim biznisom i predložiti najbolje rješenje.',
        emailLabel: 'E-mail',
        webLabel: 'Web',
      }
    : {
        eyebrow: 'Contact',
        title: 'Your competition isn’t waiting — neither should you.',
        lead: 'Leave us your details and we’ll get back to you shortly. We’ll happily get to know your business and suggest the best solution.',
        emailLabel: 'Email',
        webLabel: 'Web',
      };
---

<section class="section section-first pt-28 md:pt-32">
  <div class="container-page grid md:grid-cols-2 gap-12 items-start">
    <div data-reveal>
      <p class="eyebrow mb-3">{c.eyebrow}</p>
      <h1 class="font-display text-4xl md:text-5xl font-black leading-tight tracking-tight text-ink">{c.title}</h1>
      <p class="mt-6 text-lg text-black/65 max-w-md">{c.lead}</p>
      <div class="mt-8 space-y-4">
        <div>
          <div class="font-mono text-xs uppercase tracking-wider text-black/45">{c.emailLabel}</div>
          <a href="mailto:info@seolick.me" class="text-lg font-bold text-ink hover:text-red transition-colors">info@seolick.me</a>
        </div>
        <div>
          <div class="font-mono text-xs uppercase tracking-wider text-black/45">{c.webLabel}</div>
          <a href="https://seolick.me" class="text-lg font-bold text-ink hover:text-red transition-colors">seolick.me</a>
        </div>
      </div>
    </div>
    <div class="border border-black/[0.12] bg-white p-6 md:p-8" data-reveal style="--d:120ms">
      <InquiryForm />
    </div>
  </div>
</section>
