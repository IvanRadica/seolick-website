---
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/utils';
import { homeContent } from '../../content/home';
import FaqAccordion from '../FaqAccordion.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizePath(path, lang);
const c = homeContent[lang];
---

<!-- HERO -->
<section class="relative overflow-hidden bg-black text-white">
  <video
    class="absolute inset-0 h-full w-full object-cover opacity-60 motion-reduce:hidden"
    autoplay muted loop playsinline preload="metadata" aria-hidden="true">
    <source src="/video/hero-liquid.mp4" type="video/mp4" />
  </video>
  <div class="absolute inset-0 bg-black/50" aria-hidden="true"></div>
  <div class="absolute inset-0 opacity-[0.07]" aria-hidden="true"
    style="background-image: radial-gradient(circle at 50% 0%, #e12c2c 0%, transparent 60%);"></div>
  <div class="container-page relative py-24 md:py-32 text-center">
    <p class="eyebrow mb-6">{c.hero.eyebrow}</p>
    <h1 class="text-4xl md:text-6xl font-black leading-[1.05] max-w-4xl mx-auto">
      {c.hero.titleA}<br /><span class="text-red">{c.hero.titleB}</span>
    </h1>
    <p class="mt-6 text-lg text-gray-200 max-w-2xl mx-auto">{c.hero.sub}</p>
    <div class="mt-9 flex flex-col items-center gap-2">
      <button data-open-popup class="btn btn-primary text-base px-9 py-4">{c.hero.cta}</button>
      <span class="text-xs text-gray-500 font-mono">* {c.hero.microcopy}</span>
    </div>
  </div>
</section>

<!-- PROBLEM -->
<section class="container-page py-20 md:py-28">
  <p class="eyebrow mb-3">{c.problem.eyebrow}</p>
  <h2 class="text-3xl md:text-4xl font-black max-w-3xl leading-tight">{c.problem.title}</h2>
  <div class="mt-10 grid gap-5 md:grid-cols-3">
    {c.problem.items.map((item, i) => (
      <div class="border border-gray-200 rounded-lg p-6">
        <div class="font-mono text-red font-bold text-sm mb-3">{String(i + 1).padStart(2, '0')}</div>
        <p class="text-gray-700 leading-relaxed">{item}</p>
      </div>
    ))}
  </div>
  <p class="mt-10 text-xl font-bold max-w-2xl">{c.problem.close}</p>
</section>

<!-- SOLUTION / LICK OVERVIEW -->
<section class="bg-gray-50 border-y border-gray-200">
  <div class="container-page py-20 md:py-28">
    <p class="eyebrow mb-3">{c.solution.eyebrow}</p>
    <h2 class="text-3xl md:text-4xl font-black max-w-3xl leading-tight">{c.solution.title}</h2>
    <div class="mt-6 max-w-3xl space-y-4 text-gray-700 leading-relaxed">
      <p>{c.solution.body}</p>
      <p>{c.solution.body2}</p>
    </div>
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {c.solution.pillars.map((pl) => (
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <div class="font-mono font-black text-4xl text-red mb-3">{pl.k}</div>
          <h3 class="font-bold text-lg mb-2">{pl.title}</h3>
          <p class="text-sm text-gray-700 leading-relaxed">{pl.desc}</p>
        </div>
      ))}
    </div>
    <a href={p('/lick')} class="btn btn-ghost mt-10">{c.solution.cta} &rarr;</a>
  </div>
</section>

<!-- GUIDES -->
<section class="container-page py-20 md:py-28">
  <div class="grid md:grid-cols-2 gap-12 items-start">
    <div>
      <p class="eyebrow mb-3">{c.guides.eyebrow}</p>
      <h2 class="text-3xl md:text-4xl font-black leading-tight">{c.guides.title}</h2>
    </div>
    <div class="space-y-4 text-gray-700 leading-relaxed">
      <p>{c.guides.body}</p>
      <p>{c.guides.body2}</p>
      <p>{c.guides.body3}</p>
      <div class="grid grid-cols-2 gap-4 pt-4">
        {c.guides.people.map((person) => (
          <div class="border border-gray-200 rounded-lg p-5">
            <div class="w-14 h-14 rounded-full bg-black text-white font-mono font-bold grid place-items-center text-xl mb-3">
              {person.name[0]}
            </div>
            <div class="font-bold">{person.name}</div>
            <div class="text-xs text-gray-500 font-mono mt-1">{person.role}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- SOCIAL PROOF -->
<section class="bg-black text-white">
  <div class="container-page py-20 md:py-28 text-center">
    <p class="eyebrow mb-3">{c.proof.eyebrow}</p>
    <h2 class="text-3xl md:text-4xl font-black max-w-3xl mx-auto leading-tight">{c.proof.title}</h2>
    <p class="mt-3 text-gray-500">{c.proof.sub}</p>
    <div class="mt-12 flex flex-wrap justify-center gap-x-10 gap-y-6">
      {c.proof.clients.map((client) => (
        <span class="font-mono text-gray-200 text-sm md:text-base font-medium">{client}</span>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="container-page py-20 md:py-28 text-center">
  <h2 class="text-3xl md:text-5xl font-black max-w-3xl mx-auto leading-tight">{c.finalCta.title}</h2>
  <p class="mt-5 text-lg text-gray-700 max-w-2xl mx-auto">{c.finalCta.sub}</p>
  <button data-open-popup class="btn btn-primary text-base px-9 py-4 mt-9">{c.finalCta.cta}</button>
</section>

<!-- FAQ -->
<section id="faq" class="bg-gray-50 border-t border-gray-200">
  <div class="container-page py-20 md:py-28 max-w-3xl">
    <p class="eyebrow mb-3">FAQ</p>
    <h2 class="text-3xl md:text-4xl font-black mb-10 leading-tight">{c.faqTitle}</h2>
    <FaqAccordion items={c.faq} />
  </div>
</section>
