---
import { getLangFromUrl, localizePath } from '../../i18n/utils';
import { homeContent } from '../../content/home';
import { resultsContent } from '../../content/results';
import HeroLick from '../HeroLick.astro';
import FaqAccordion from '../FaqAccordion.astro';

const lang = getLangFromUrl(Astro.url);
const p = (path: string) => localizePath(path, lang);
const c = homeContent[lang];
const r = resultsContent[lang];

const teamPhotos: Record<string, string> = {
  Marko: '/team/marko.jpg',
  Ivan: '/team/ivan.jpg',
};

// Red stroke pictograms from the Claude Design handoff (inner SVG markup;
// rendered inside a 24x24 viewBox wrapper below).
const icons: Record<string, string> = {
  // problem cards
  eyeOff:
    '<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"></path><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"></path><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"></path><line x1="2" y1="2" x2="22" y2="22"></line>',
  stopwatch:
    '<line x1="10" y1="2" x2="14" y2="2"></line><line x1="12" y1="14" x2="15" y2="11"></line><circle cx="12" cy="14" r="8"></circle>',
  banknote:
    '<rect x="2" y="6" width="20" height="12" rx="2"></rect><circle cx="12" cy="12" r="2"></circle><path d="M6 12h.01"></path><path d="M18 12h.01"></path>',
  messageCircle: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>',
  // services teaser
  compass:
    '<circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>',
  layers:
    '<polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline>',
  trendingUp:
    '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline>',
  // case study rows
  sail: '<path d="M22 18H2a4 4 0 0 0 4 4h12a4 4 0 0 0 4-4Z"></path><path d="M21 14 10 2 3 14h18Z"></path><path d="M10 2v16"></path>',
  shirt:
    '<path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"></path>',
  terrain: '<path d="m8 3 4 8 5-5 5 15H2L8 3z"></path>',
  anchor:
    '<circle cx="12" cy="5" r="3"></circle><line x1="12" y1="22" x2="12" y2="8"></line><path d="M5 12H2a10 10 0 0 0 20 0h-3"></path>',
  cross:
    '<path d="M11 2a2 2 0 0 0-2 2v5H4a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2h5v5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-5h5a2 2 0 0 0 2-2v-2a2 2 0 0 0-2-2h-5V4a2 2 0 0 0-2-2h-2z"></path>',
  plane:
    '<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"></path>',
};

const problemIcons = ['banknote', 'eyeOff', 'messageCircle'];
const serviceIcons = ['compass', 'layers', 'trendingUp'];
---

<HeroLick />

<!-- POSITIONING BAND -->
<section class="section section-first">
  <div class="container-page max-w-4xl text-center" data-reveal>
    <p class="eyebrow mb-5">{c.intro.eyebrow}</p>
    <p class="font-display text-2xl md:text-4xl font-black leading-[1.2] tracking-tight text-balance text-ink whitespace-pre-line">
      {c.intro.text}
    </p>
    <button data-open-popup class="btn btn-primary mt-9">{c.intro.cta}</button>
  </div>
</section>

<!-- PROBLEM -->
<section class="section">
  <div class="container-page">
    <p class="section-label" data-reveal>{c.problem.eyebrow}</p>
    <h2 class="section-title max-w-3xl" data-reveal>{c.problem.title}</h2>
    <div class="grid-frame grid-3 mt-12">
      {c.problem.items.map((item, i) => (
        <div class="card" data-reveal style={`--d:${i * 90}ms`}>
          <div class="flex items-center justify-between">
            <div class="font-mono text-red font-bold text-sm">{String(i + 1).padStart(2, '0')}</div>
            <svg viewBox="0 0 24 24" fill="none" stroke="#e12c2c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-[30px] h-[30px]" aria-hidden="true" set:html={icons[problemIcons[i]]} />
          </div>
          <p class="card-desc text-black/70">{item}</p>
        </div>
      ))}
    </div>
    <p class="mt-10 text-xl md:text-2xl font-bold max-w-3xl text-ink whitespace-pre-line" data-reveal>{c.problem.close}</p>
  </div>
</section>

<!-- L.I.C.K. FRAMEWORK — tall letter cards with red hover overlay -->
<section id="framework" class="section">
  <div class="container-page">
    <p class="section-label" data-reveal>{c.framework.eyebrow}</p>
    <h2 class="section-title max-w-3xl" data-reveal>
      <span class="title-lick">{c.framework.title}<svg viewBox="0 0 100 8" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" d="M1,6 Q 25,1 50,4.5 T 99,3" /></svg></span>
    </h2>
    <p class="section-intro whitespace-pre-line" data-reveal>{c.framework.intro}</p>
    <div class="grid-frame grid-4 mt-12">
      {c.framework.pillars.map((pl, i) => (
        <div class="pillar-card" data-pillar tabindex="0">
          <div class="pillar-letter wheel" style={`--d:${i * 110}ms`}>{pl.letter}</div>
          <div class="pillar-kicker">{pl.name}</div>
          <div class="pillar-rule"></div>
          <div class="pillar-overlay">
            <div class="flex items-baseline justify-between">
              <span class="ov-letter">{pl.letter}</span>
              <span class="ov-count">{String(i + 1).padStart(2, '0')} / 04</span>
            </div>
            <div class="ov-kicker">{pl.name}</div>
            <p class="ov-lead">{pl.lead}</p>
            <p class="ov-desc">{pl.desc}</p>
            <div class="ov-list">
              {pl.includes.map((inc) => <div>→ {inc}</div>)}
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-6 flex items-center justify-between gap-4 flex-wrap" data-reveal>
      <p class="pillar-hint">{c.framework.hint}</p>
      <a href={p('/lick')} class="btn btn-ghost">{c.framework.cta} &rarr;</a>
    </div>
  </div>
</section>

<!-- RESULTS / CASE STUDIES — warm band -->
<section id="results" class="section section-band">
  <div class="container-page">
    <p class="section-label" data-reveal>{r.eyebrow}</p>
    <div class="grid md:grid-cols-2 gap-x-12 gap-y-4 items-end" data-reveal>
      <h2 class="section-title !mb-0">
        <span class="title-lick">{r.title}<svg viewBox="0 0 100 8" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" d="M1,5 Q 30,0.5 55,4 T 99,4.5" /></svg></span>
      </h2>
      <p class="text-black/55 leading-relaxed">{r.intro}</p>
    </div>

    <div class="counter-row mt-12" data-reveal>
      {r.counters.map((ct) => (
        <div class="counter">
          <span class="counter-number"><span data-countup={ct.number}>{ct.number}</span><em>{ct.suffix}</em></span>
          <span class="counter-label">{ct.label}</span>
        </div>
      ))}
    </div>

    <div>
      {r.cases.map((cs, i) => (
        <div class="result-row" data-reveal style={`--d:${(i % 3) * 70}ms`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="#e12c2c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="rr-icon" aria-hidden="true" set:html={icons[cs.icon]} />
          <div class="case-industry">{cs.name ?? cs.industry}</div>
          <div class="rr-text">{cs.challenge} <span class="arrow">→</span> {cs.solution}</div>
          <div class="rr-result">
            <div class="rr-number">{cs.result}</div>
            <div class="rr-sub">{cs.resultSub}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Team's earlier track record (self-reported, clearly labelled) -->
    <div class="mt-14 border border-black/[0.12] bg-white p-6 md:p-8" data-reveal>
      <p class="section-label !mb-2">{r.priorTitle}</p>
      <p class="text-black/55 text-sm mb-6">{r.priorNote}</p>
      <div class="grid gap-4 sm:grid-cols-3">
        {r.prior.map((pr) => (
          <div class="border-l-2 border-red/60 pl-4">
            <div class="font-mono text-[11px] uppercase tracking-[0.15em] text-black/50 mb-1">{pr.industry}</div>
            <div class="font-display font-black text-lg text-ink leading-tight">{pr.result}</div>
          </div>
        ))}
      </div>
    </div>

    <p class="mt-8 font-mono text-[11px] text-black/45 leading-relaxed max-w-2xl" data-reveal>{r.disclaimer}</p>
  </div>
</section>

<!-- SERVICES TEASER -->
<section id="services" class="section">
  <div class="container-page">
    <p class="section-label" data-reveal>{c.servicesTeaser.eyebrow}</p>
    <h2 class="section-title max-w-3xl" data-reveal>{c.servicesTeaser.title}</h2>
    <p class="section-intro" data-reveal>{c.servicesTeaser.intro}</p>
    <div class="grid-frame grid-3 mt-12">
      {c.servicesTeaser.items.map((s, i) => (
        <div class="card" data-reveal style={`--d:${i * 90}ms`}>
          <div class="flex items-center justify-between">
            <div class="font-mono text-red text-sm font-semibold tracking-[0.2em]">{s.num}</div>
            <svg viewBox="0 0 24 24" fill="none" stroke="#e12c2c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-[30px] h-[30px]" aria-hidden="true" set:html={icons[serviceIcons[i]]} />
          </div>
          <h3 class="card-title">{s.name}</h3>
          <div class="card-rule"></div>
          <p class="card-desc">{s.desc}</p>
          <div class="font-display font-black text-xl text-ink mt-2">{s.price}</div>
        </div>
      ))}
    </div>
    <a href={p('/usluge')} class="btn btn-ghost mt-10" data-reveal>{c.servicesTeaser.cta} &rarr;</a>
  </div>
</section>

<!-- GUIDES / TEAM -->
<section class="section">
  <div class="container-page grid md:grid-cols-2 gap-12 items-start">
    <div data-reveal>
      <p class="section-label">{c.guides.eyebrow}</p>
      <h2 class="section-title">{c.guides.title}</h2>
    </div>
    <div class="space-y-4 text-black/65 leading-relaxed" data-reveal>
      <p>{c.guides.body}</p>
      <p>{c.guides.body2}</p>
      <p>{c.guides.body3}</p>
      <div class="grid grid-cols-2 gap-4 pt-4">
        {c.guides.people.map((person) => (
          <div class="border border-black/[0.12] p-6 flex flex-col gap-3">
            {teamPhotos[person.name] ? (
              <img
                src={teamPhotos[person.name]}
                alt={person.name}
                width="88"
                height="88"
                loading="lazy"
                class="w-[88px] h-[88px] rounded-full object-cover"
              />
            ) : (
              <div class="w-[88px] h-[88px] rounded-full bg-red text-white font-display font-black grid place-items-center text-3xl">
                {person.name[0]}
              </div>
            )}
            <div>
              <div class="font-bold text-ink">{person.name}</div>
              <div class="text-[11px] text-black/50 font-mono mt-1">{person.role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- TESTIMONIAL — warm band -->
<section class="section section-band">
  <div class="container-page max-w-4xl" data-reveal>
    <p class="section-label">{c.testimonial.eyebrow}</p>
    <blockquote class="font-display text-2xl md:text-3xl font-bold leading-snug text-balance text-ink">
      <span class="text-red">“</span>{c.testimonial.quote}<span class="text-red">”</span>
    </blockquote>
    <div class="mt-6 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-black/[0.06] grid place-items-center font-mono text-red text-sm">★</div>
      <div>
        <div class="font-bold text-ink text-sm">{c.testimonial.author}</div>
        <div class="text-black/50 text-xs font-mono">{c.testimonial.role} · {c.testimonial.source}</div>
      </div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="section">
  <div class="container-page text-center" data-reveal>
    <h2 class="section-title max-w-3xl mx-auto">{c.finalCta.title}</h2>
    <p class="mt-4 text-lg text-black/65 max-w-2xl mx-auto">{c.finalCta.sub}</p>
    <button data-open-popup class="btn btn-primary mt-9">{c.finalCta.cta}</button>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="section">
  <div class="container-page max-w-3xl">
    <p class="section-label" data-reveal>FAQ</p>
    <h2 class="section-title mb-10" data-reveal>{c.faqTitle}</h2>
    <FaqAccordion items={c.faq} />
  </div>
</section>

<script>
  // Touch/keyboard fallback for the pillar overlay (hover handles pointers).
  document.querySelectorAll('[data-pillar]').forEach((card) => {
    card.addEventListener('click', () => card.classList.toggle('is-open'));
    card.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        card.classList.toggle('is-open');
      }
    });
  });
</script>
