---
import { getLangFromUrl } from '../../i18n/utils';
import { servicesContent } from '../../content/services';
import InquiryForm from '../InquiryForm.astro';

const lang = getLangFromUrl(Astro.url);
const c = servicesContent[lang];
---

<section class="bg-black text-white">
  <div class="container-page py-20 md:py-24 text-center">
    <p class="eyebrow mb-3">{c.eyebrow}</p>
    <h1 class="text-4xl md:text-5xl font-black">{c.title}</h1>
    <p class="mt-2 text-lg text-red font-bold italic">{c.subtitle}</p>
    <p class="mt-6 text-gray-200 max-w-2xl mx-auto leading-relaxed">{c.intro}</p>
    <p class="mt-4 text-gray-500 max-w-2xl mx-auto text-sm">{c.introNote}</p>
  </div>
</section>

<div class="container-page py-16 md:py-24 space-y-16">
  {c.items.map((s) => (
    <article id={s.id} class="grid md:grid-cols-3 gap-8 scroll-mt-20">
      <div class="md:sticky md:top-20 self-start">
        <div class="font-mono text-red font-black text-sm mb-2">{s.num}</div>
        <h2 class="text-2xl font-black">{s.name}</h2>
        <p class="text-gray-500 mt-2 text-sm">{s.tagline}</p>
        <div class="mt-4 inline-block font-mono text-xs border border-gray-200 rounded px-3 py-1">{c.priceLabel}</div>
        <div class="mt-4">
          <button data-open-popup class="btn btn-primary text-sm w-full md:w-auto">{c.cta}</button>
        </div>
      </div>
      <div class="md:col-span-2 space-y-6">
        {s.blocks.map((b) => (
          <div>
            <h3 class="font-bold text-lg mb-2">{b.h}</h3>
            <p class="text-gray-700 leading-relaxed">{b.p}</p>
          </div>
        ))}
      </div>
    </article>
  ))}
</div>

<section id="upit" class="bg-gray-50 border-t border-gray-200 scroll-mt-16">
  <div class="container-page py-20 md:py-24 grid md:grid-cols-2 gap-12 items-start">
    <div>
      <h2 class="text-3xl md:text-4xl font-black leading-tight">{c.formTitle}</h2>
      <p class="mt-4 text-lg text-gray-700">{c.formSub}</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-6 md:p-8">
      <InquiryForm />
    </div>
  </div>
</section>
