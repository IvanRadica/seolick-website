---
import { getLangFromUrl } from '../../i18n/utils';
import { servicesV2Content } from '../../content/services-v2';
import InquiryForm from '../InquiryForm.astro';

const lang = getLangFromUrl(Astro.url);
const c = servicesV2Content[lang];
---

<!-- HEADER -->
<section class="section section-first pt-28 md:pt-32">
  <div class="container-page text-center" data-reveal>
    <p class="eyebrow mb-4">{c.eyebrow}</p>
    <h1 class="font-display text-4xl md:text-6xl font-black tracking-tight text-ink">{c.title}</h1>
    <p class="mt-3 text-lg text-red font-bold">{c.subtitle}</p>
    <p class="mt-6 text-black/65 max-w-2xl mx-auto leading-relaxed">{c.intro}</p>
  </div>
</section>

<!-- TRIO — fused grid-frame, sharp corners -->
<section class="section">
  <div class="container-page">
    <div class="grid-frame grid-3">
      {c.trio.map((s, i) => (
        <article class="card" data-reveal style={`--d:${i * 120}ms`}>
          <div class="font-mono text-red font-black text-sm">{s.num}</div>
          <h2 class="card-title">{s.name}</h2>
          <div class="font-display font-black text-lg text-ink">{s.price}</div>
          <p class="text-black/50 text-sm italic">{s.tagline}</p>
          <p class="card-desc">{s.desc}</p>
          <ul class="space-y-2 text-sm text-black/70 flex-none mt-1">
            {s.bullets.map((b) => (
              <li class="flex gap-2"><span class="text-red font-bold">→</span><span>{b}</span></li>
            ))}
          </ul>
          <div class="mt-auto pt-5">
            <button data-open-popup class="btn btn-primary text-sm w-full">{c.cta}</button>
          </div>
        </article>
      ))}
    </div>
    <p class="mt-8 text-center text-black/50 text-sm max-w-3xl mx-auto leading-relaxed">{c.pathNote}</p>
  </div>
</section>

<!-- RETAINER TIERS — warm band -->
<section class="section section-band">
  <div class="container-page">
    <div class="text-center">
      <p class="mx-auto mb-6 max-w-xl text-sm font-mono text-black/50" data-reveal>{c.tiers.bridge}</p>
      <p class="eyebrow mb-3" data-reveal>{c.tiers.eyebrow}</p>
      <h2 class="section-title" data-reveal>{c.tiers.title}</h2>
      <p class="mt-3 text-black/65" data-reveal>{c.tiers.subtitle}</p>
    </div>
    <div class="mt-12 grid md:grid-cols-3 gap-6 items-stretch">
      {c.tiers.plans.map((plan, i) => (
        <div class={`relative flex flex-col p-6 md:p-8 bg-white ${plan.featured ? 'border-2 border-red bg-red/[0.06]' : 'border border-black/[0.12]'}`} data-reveal style={`--d:${i * 120}ms`}>
          {plan.featured && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-red text-white font-mono text-xs font-bold px-3 py-1 rounded-[2px]">{c.tiers.featuredLabel}</div>
          )}
          <h3 class="font-display font-black text-xl text-ink">{plan.name}</h3>
          <div class="mt-1 font-mono text-xs text-black/50">{plan.capacity}</div>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="font-display text-3xl font-black text-ink" data-countup={plan.price}>{plan.price}</span>
            <span class="text-sm text-black/50">{c.tiers.perMonth}</span>
          </div>
          <p class="mt-5 text-sm leading-relaxed flex-1 text-black/65">{plan.team}</p>
          <div class="mt-6">
            <button data-open-popup class="btn btn-primary text-sm w-full">{c.tiers.cta}</button>
          </div>
        </div>
      ))}
    </div>
    <p class="mt-8 text-center text-black/50 text-sm">{c.tiers.note}</p>
  </div>
</section>

<!-- RELATED SERVICES — fused grid-frame -->
<section class="section">
  <div class="container-page">
    <div class="text-center">
      <p class="eyebrow mb-3" data-reveal>{c.width.eyebrow}</p>
      <h2 class="section-title" data-reveal>{c.width.title}</h2>
      <p class="mt-3 text-black/65" data-reveal>{c.width.subtitle}</p>
    </div>
    <div class="grid-frame grid-3 mt-12">
      {c.width.items.map((it, i) => (
        <div class="card" data-reveal style={`--d:${i * 110}ms`}>
          <h3 class="font-bold text-lg text-ink">{it.name}</h3>
          <p class="card-desc">{it.desc}</p>
          <div class="mt-2 inline-block self-start font-mono text-xs border border-black/[0.18] rounded-[2px] px-3 py-1 text-black/70">{it.price}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- INQUIRY -->
<section id="upit" class="section scroll-mt-16">
  <div class="container-page grid md:grid-cols-2 gap-12 items-start">
    <div data-reveal>
      <h2 class="section-title">{c.formTitle}</h2>
      <p class="mt-4 text-lg text-black/65">{c.formSub}</p>
    </div>
    <div class="border border-black/[0.12] bg-white p-6 md:p-8">
      <InquiryForm />
    </div>
  </div>
</section>
