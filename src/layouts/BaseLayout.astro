---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PopupForm from '../components/PopupForm.astro';
import { getLangFromUrl, getAlternatePath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, ogImage = '/og-default.svg', noindex = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const hrHref = new URL(getAlternatePath(Astro.url, 'hr'), Astro.site).href;
const enHref = new URL(getAlternatePath(Astro.url, 'en'), Astro.site).href;
const ogUrl = new URL(ogImage, Astro.site).href;

// Canonical broad-ICP positioning (Second Brain wiki is source of truth).
const orgDescription =
  'Strateška SEO agencija za brendove koji žive od upita i rezervacija — L.I.C.K. framework.';

const org = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SEO LICK',
  url: 'https://seolick.me',
  description: orgDescription,
  email: 'ivan@seolick.me',
  sameAs: [],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="hr" href={hrHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={hrHref} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:locale" content={lang === 'hr' ? 'hr_HR' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800;900&family=Roboto:ital,wght@0,300;0,400;0,500;0,700;0,900;1,400&family=Roboto+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(org)} />
    <script is:inline>
      document.documentElement.classList.add('fx-ready');
    </script>
  </head>
  <body>
    <div class="scroll-progress" data-scroll-progress aria-hidden="true"></div>
    <Header />
    <main class="fx">
      <slot />
    </main>
    <Footer />
    <PopupForm />
    {(
      <script>
        // Motion runtime — self-guards on main.fx and reduced-motion.
        const root = document.querySelector('main.fx');
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (root && !reduce) {
          // Scroll reveal + grouped triggers (wheels, roadmap, arrows, lick underlines).
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-visible');
                  io.unobserve(e.target);
                }
              }
            },
            { threshold: 0.18, rootMargin: '0px 0px -8% 0px' }
          );
          root
            .querySelectorAll('[data-reveal], .wheel, .rm-grid, .svc-arrow, .title-lick')
            .forEach((el) => io.observe(el));

          // Red-thread scroll progress.
          const progress = document.querySelector('[data-scroll-progress]');
          if (progress) {
            let ticking = false;
            const paint = () => {
              const max = document.documentElement.scrollHeight - innerHeight;
              progress.style.transform = `scaleX(${max > 0 ? Math.min(1, scrollY / max) : 0})`;
              ticking = false;
            };
            addEventListener('scroll', () => {
              if (!ticking) { ticking = true; requestAnimationFrame(paint); }
            }, { passive: true });
            paint();
          }

          // Pointer-tracked spotlight on grid cards (hover-capable pointers only).
          if (matchMedia('(hover: hover) and (pointer: fine)').matches) {
            root.querySelectorAll('.card').forEach((card) => {
              card.addEventListener('pointermove', (e) => {
                const r = card.getBoundingClientRect();
                card.style.setProperty('--mx', `${e.clientX - r.left}px`);
                card.style.setProperty('--my', `${e.clientY - r.top}px`);
              });
            });

            // Magnetic primary CTAs — ease toward the pointer, snap back on leave.
            document.querySelectorAll('.btn-primary').forEach((btn) => {
              btn.addEventListener('pointermove', (e) => {
                const r = btn.getBoundingClientRect();
                const dx = e.clientX - (r.left + r.width / 2);
                const dy = e.clientY - (r.top + r.height / 2);
                btn.style.setProperty('--tx', `${dx * 0.14}px`);
                btn.style.setProperty('--ty', `${dy * 0.22}px`);
              });
              btn.addEventListener('pointerleave', () => {
                btn.style.setProperty('--tx', '0px');
                btn.style.setProperty('--ty', '0px');
              });
            });
          }

          // Price count-up.
          const parsePrice = (s) => {
            const digits = (s.match(/[\d.]/g) || []).join('').replace(/\./g, '');
            return { value: parseInt(digits, 10) || 0, raw: s };
          };
          const fmt = (n) => n.toLocaleString('hr-HR');
          const countEls = root.querySelectorAll('[data-countup]');
          const cio = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (!e.isIntersecting) continue;
                const el = e.target;
                cio.unobserve(el);
                const target = el.getAttribute('data-countup') || el.textContent || '';
                const { value } = parsePrice(target);
                if (!value) continue;
                const prefix = target.match(/^[^\d]*/)[0] || '';
                const suffix = target.match(/[^\d.]*$/)[0] || '';
                const start = performance.now();
                const dur = 1100;
                const tick = (now) => {
                  const t = Math.min(1, (now - start) / dur);
                  const eased = 1 - Math.pow(1 - t, 3);
                  el.textContent = prefix + fmt(Math.round(value * eased)) + suffix;
                  if (t < 1) requestAnimationFrame(tick);
                  else el.textContent = target;
                };
                requestAnimationFrame(tick);
              }
            },
            { threshold: 0.6 }
          );
          countEls.forEach((el) => cio.observe(el));
        }
      </script>
    )}
  </body>
</html>
